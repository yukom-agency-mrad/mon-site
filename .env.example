# Resend — envoi des emails du formulaire de contact
# Crée un compte sur https://resend.com, ajoute et vérifie le domaine yukom.agency,
# puis colle ta clé API ci-dessous. Sans clé, le formulaire fonctionne en mode "test"
# (le message est loggé dans les logs serveur mais aucun email n'est envoyé).
RESEND_API_KEY=

# Email d'expédition (doit appartenir à un domaine vérifié sur Resend).
# Par défaut : "Yukom <onboarding@resend.dev>" (sandbox Resend, limité aux emails vérifiés).
# Exemple : CONTACT_FROM_EMAIL="Yukom <hello@yukom.agency>"
CONTACT_FROM_EMAIL=

# Adresse qui reçoit les messages du formulaire.
# Par défaut : maud_mrad@hotmail.fr
CONTACT_TO_EMAIL=

# Google Places API — affichage des avis Google sur la home
# 1) Crée un projet sur https://console.cloud.google.com
# 2) Active "Places API (New)"
# 3) Crée une clé API et restreins-la à ton domaine
# 4) Récupère ton Place ID via https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
